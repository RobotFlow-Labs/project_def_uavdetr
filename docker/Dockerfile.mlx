# DEF-UAVDETR MLX image (Apple Silicon)
FROM python:3.11-slim

WORKDIR /opt/anima/module

RUN pip install --no-cache-dir uv

COPY pyproject.toml .
RUN uv venv .venv --python python3.11 \
    && . .venv/bin/activate \
    && uv pip install -e ".[serve]"

COPY . .

ENV ANIMA_DEVICE=cpu
ENV ANIMA_MODULE_NAME=def-uavdetr
EXPOSE 8080

CMD [".venv/bin/python", "-m", "uvicorn", "anima_def_uavdetr.api.app:app", "--host", "0.0.0.0", "--port", "8080"]
